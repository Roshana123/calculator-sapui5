<mvc:View
    controllerName="com.demo.b74sapui5app.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
>
    <Page
        id="page"
        title="Calculator"
        titleAlignment="center"

    >
        <content>
            <VBox
                width="30%"
                class="bgcolor"
            
            >
              
               

                <Label
                    text="Number 1"
                    labelFor="number1"
                
                />
                <Input
                    id="number1"
                    type="Number"
                    placeholder="Enter Number1"
                      class="labelcolor"
                />
                <Label
                    text="Number 2"
                    labelFor="number2"
                  
                />
                <Input
                    id="number2"
                    type="Number"
                    placeholder="Enter Number2"
                      class="labelcolor"
                />
                <HBox>
                    <Button
                        text="+"
                        press="onAdd"
                    />
                    <Button
                        text="-"
                        press="onSubtract"
                    />
                    <Button
                        text="*"
                        press="onMultiply"
                    />
                    <Button
                        text="/"
                        press="onDivide"
                    />
                </HBox>
                <Label
                    text="Result"
                    labelFor="result"
                    
                />
                <Input
                    id="result"
                    placeholder="Enter Result"
                      class="labelcolor"
                />
            </VBox>
        </content>
    </Page>
</mvc:View>
