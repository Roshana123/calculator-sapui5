<mvc:View
    controllerName="com.demo.b74sapui5app.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page
        id="page"
        title="{i18n>calculatorTitle}"
        titleAlignment="center"
    >
        <content>
            <VBox
                width="30%"
                class="bgcolor"
            >
                <Label
                    text="{i18n>number1}"
                    labelFor="number1"
                    class="labelColor"
                />
                <Input
                    id="number1"
                    type="Number"
                    placeholder="{i18n>enterNumber1}"
                    class="labelColor"
                />
                <Label
                    text="{i18n>number2}"
                    labelFor="number2"
                    class="labelColor"
                />
                <Input
                    id="number2"
                    type="Number"
                    placeholder="{i18n>enterNumber2}"
                    class="labelColor"
                />
                <HBox>
                    <Button text="+" press="onAdd" />
                    <Button text="-" press="onSubtract" />
                    <Button text="*" press="onMultiply" />
                    <Button text="/" press="onDivide" />
                </HBox>
                <Label
                    text="{i18n>result}"
                    labelFor="result"
                    class="labelColor"
                />
                <Input
                    id="result"
                    placeholder="{i18n>enterResult}"
                    editable="false"
                    class="labelColor"
                />
            </VBox>
        </content>
    </Page>
</mvc:View>
